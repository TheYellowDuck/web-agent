# Copy to .env and fill in the keys for whichever provider(s) you use.
# The agent is provider-agnostic — pick a model with --model and the right
# key is read from here.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Gemini ---
GEMINI_API_KEY=
# or GOOGLE_API_KEY=

# --- Default model for build/dev runs ---
# Per the project plan: develop against one capable-but-cheap model, run the
# multi-model sweep only once the harness is stable.
WEBAGENT_MODEL=claude-sonnet-4-6

# --- WebArena self-hosted site base URLs (set when running the sandbox) ---
WA_SHOPPING=
WA_SHOPPING_ADMIN=
WA_REDDIT=
WA_GITLAB=
WA_MAP=
WA_WIKIPEDIA=
WA_HOMEPAGE=
